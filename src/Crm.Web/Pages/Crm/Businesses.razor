@page "/crm/businesses"
@attribute [Authorize]

@inject IBusinessService BusinessService
@inject ICurrentUser CurrentUser
@inject IPermissionService PermissionService

<h3>Businesses</h3>

@if (!_canViewBusinesses)
{
    <p>Not authorized.</p>
    return;
}

@if (_canCreateBusinesses)
{
    <p><a class="btn btn-primary" href="/crm/businesses/new">New Business</a></p>
}

@if (_rows is null)
{
    <p>Loading...</p>
}
else
{
    <table class="table">
        <thead>
            <tr><th>Name</th><th>Email</th><th>Phone</th></tr>
        </thead>
        <tbody>
            @foreach (var b in _rows)
            {
                <tr>
                    <td><a href="/crm/businesses/@b.Id">@b.Name</a></td>
                    <td>@b.Email</td>
                    <td>@b.Phone</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {



    private IReadOnlyList<BusinessDto>? _rows;
    private bool _canViewBusinesses;
    private bool _canCreateBusinesses; 

    protected override async Task OnInitializedAsync()
    {
        _rows = await BusinessService.GetBusinessesAsync(CurrentUser.UserId!);

        if (!CurrentUser.IsAuthenticated || string.IsNullOrWhiteSpace(CurrentUser.UserId))
            return;

        var userId = CurrentUser.UserId;

       _canCreateBusinesses =  await PermissionService.HasPermissionAsync(CurrentUser.UserId!, PermissionKeys.Crm.BusinessCreate);
        _canViewBusinesses = await PermissionService.HasPermissionAsync(userId, PermissionKeys.Crm.BusinessView);
        
    }
}