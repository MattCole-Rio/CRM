@page "/crm/businesses/new"
@using global::Crm.Application.CRM
@using global::Crm.Application.Permissions
@inject global::Crm.Application.CRM.IBusinessService Businesses
@inject global::Crm.Application.Common.ICurrentUser CurrentUser
@inject global::Crm.Application.Permissions.IPermissionService PermissionService
@inject global::Microsoft.AspNetCore.Components.NavigationManager Nav
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<h3>New Business</h3>

@if (!_canCreateBusinesses)
{
    <p>Not authorized.</p>
    return;
}

<EditForm Model="_model" OnValidSubmit="Save">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="_model.Name" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText class="form-control" @bind-Value="_model.Email" />
    </div>

    <div class="mb-3">
        <label class="form-label">Phone</label>
        <InputText class="form-control" @bind-Value="_model.Phone" />
    </div>

    <div class="mb-3">
        <label class="form-label">Website</label>
        <InputText class="form-control" @bind-Value="_model.Website" />
    </div>

    <button class="btn btn-primary" type="submit">Create</button>
</EditForm>

@code {

    private BusinessEditModel _model = new();
    private bool _canCreateBusinesses;



    protected override async Task OnInitializedAsync()
    {
         _canCreateBusinesses = await PermissionService.HasPermissionAsync(CurrentUser.UserId!, PermissionKeys.Crm.BusinessCreate);
    }

    private async Task Save()
    {
        var id = await Businesses.CreateAsync(CurrentUser.UserId!, _model.Name, _model.Email, _model.Phone, _model.Website);
        Nav.NavigateTo($"/crm/businesses/{id}");
    }
}