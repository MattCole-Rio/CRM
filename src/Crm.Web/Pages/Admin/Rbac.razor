@page "/admin/rbac"
@inject global::Crm.Application.Common.ICurrentUser CurrentUser
@inject global::Crm.Application.Permissions.IPermissionService PermissionService
@inject global::Crm.Infrastructure.Data.AppDbContext Db
@inject global::Microsoft.AspNetCore.Identity.RoleManager<Microsoft.AspNetCore.Identity.IdentityRole> RoleManager
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<h3>RBAC Admin</h3>

@if (!CurrentUser.IsAuthenticated || !_canManageRbac)
{
    <p>Not authorized.</p>
    return;
}

<p>
    Minimal admin view. Use Dev Seed to create baseline roles/permissions.
</p>

<h4>Roles</h4>
@if (_roles is null)
{
    <p>Loading...</p>
}
else
{
    <ul>
        @foreach (var r in _roles)
        {
            <li>
                <b>@r.Name</b>
                (<a href="/admin/rbac/role/@r.Id">edit permissions</a>)
            </li>
        }
    </ul>
}

<h4>User Overrides</h4>
<p><a href="/admin/rbac/overrides">Manage user permission overrides</a></p>

@code {
    private List<Microsoft.AspNetCore.Identity.IdentityRole>? _roles;

    private bool _canManageRbac;

    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUser.IsAuthenticated || string.IsNullOrWhiteSpace(CurrentUser.UserId))
            return;

        var userId = CurrentUser.UserId;

        _roles = RoleManager.Roles.OrderBy(r => r.Name).ToList();
        _canManageRbac = await PermissionService.HasPermissionAsync(userId, PermissionKeys.Rbac.Manage);
    
    }
}

