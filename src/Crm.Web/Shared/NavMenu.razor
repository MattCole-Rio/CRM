@using Crm.Application.Permissions
@inject Crm.Application.Common.ICurrentUser CurrentUser
@inject Crm.Application.Permissions.IPermissionService PermissionService

<nav class="navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">CRM</a>
    </div>
</nav>

<ul class="nav flex-column">
    <li class="nav-item px-3">
        <a class="nav-link" href="">Home</a>
    </li>

    @if (CurrentUser.IsAuthenticated &&  _canViewBusinesses)
    {
        <li class="nav-item px-3">
            <a class="nav-link" href="crm/businesses">Businesses</a>
        </li>
    }

    @if (CurrentUser.IsAuthenticated && _canViewContacts)
    {
        <li class="nav-item px-3">
            <a class="nav-link" href="crm/contacts">Contacts</a>
        </li>
    }

    @if (CurrentUser.IsAuthenticated && _canManageRbac)
    {
        <li class="nav-item px-3">
            <a class="nav-link" href="admin/rbac">Admin: RBAC</a>
        </li>
    }

    <li class="nav-item px-3">
        <a class="nav-link" href="admin/seed">Dev Seed</a>
    </li>
</ul>

@code {
    private bool _canViewBusinesses;
    private bool _canViewContacts;
    private bool _canManageRbac;

    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUser.IsAuthenticated || string.IsNullOrWhiteSpace(CurrentUser.UserId))
            return;

        var userId = CurrentUser.UserId;

        _canViewBusinesses = await PermissionService.HasPermissionAsync(userId, PermissionKeys.Crm.BusinessView);
        _canViewContacts = await PermissionService.HasPermissionAsync(userId, PermissionKeys.Crm.ContactView);
        _canManageRbac = await PermissionService.HasPermissionAsync(userId, PermissionKeys.Rbac.Manage);
    }
}